{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2015",
    "allowJs": true,
    "checkJs": false,
    "outDir": "build",
    "rootDir": "src",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "build"]
}