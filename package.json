{
  "scripts": {
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc"
  },
  "husky": {
    "lint-staged": {
      "*.{ts,tsx}": [
        "eslint --fix",
        "prettier --write",
        "git add"
      ]
    },
    "hooks": {
      "pre-commit": "lint-staged && npm run typecheck"
    }
  },
  "dependencies": {
    "@types/express": "latest",
    "@types/mongoose": "^5.11.97",
    "@types/node": "latest",
    "apollo-server-express": "^3.13.0",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "graphql": "^16.8.1",
    "mongoose": "^8.1.1",
    "nodemon": "^3.0.3",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "husky": "^9.0.6",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3"
  }
}
